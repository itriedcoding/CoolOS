# CoolOS Openbox Autostart
# This file is executed on login

# Set wallpaper
nitrogen --restore &

# Start panel
tint2 &

# Start compositor
picom --experimental-backends &

# Start notification daemon
dunst &

# Start clipboard manager
clipmenud &

# Start screensaver
xscreensaver -nosplash &

# Start file manager daemon
pcmanfm --daemon &

# Set keyboard repeat
xset r rate 300 50

# Set cursor theme
xsetroot -cursor_name left_ptr

# Set background color
xsetroot -solid "#282828"

# Set window decorations
xprop -root -f _NET_WM_THEME_NAME 8a -set _NET_WM_THEME_NAME "Arc-Dark"

# Set icon theme
xrdb -merge - << 'XRDB'
! CoolOS X Resources
! Cursor
*cursorTheme: Adwaita
*cursorSize: 24

! Font
*Xft.antialias: true
*Xft.hinting: true
*Xft.hintstyle: hintslight
*Xft.rgba: rgb
*Xft.autohint: false

! GTK
*Gtk/ThemeName: Arc-Dark
*Gtk/IconThemeName: Papirus-Dark
*Gtk/CursorThemeName: Adwaita
*Gtk/CursorThemeSize: 24
XRDB

# Set keyboard layout
setxkbmap -layout us -variant intl

# Enable accessibility
export GTK_MODULES="gail:atk-bridge"
export QT_ACCESSIBILITY=1
export QT_LINUX_ACCESSIBILITY_ALWAYS_ON=1

# Set language
export LANG=en_US.UTF-8
export LANGUAGE=en_US:en
export LC_ALL=en_US.UTF-8
