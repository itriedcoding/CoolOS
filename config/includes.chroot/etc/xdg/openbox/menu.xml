<?xml version="1.0" encoding="utf-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">
  <menu id="root-menu" label="CoolOS Menu">
    <separator label="Applications"/>
    
    <!-- Internet -->
    <menu id="internet" label="Internet">
      <item label="Firefox ESR">
        <action name="Execute"><command>firefox-esr</command></action>
      </item>
      <item label="Chromium">
        <action name="Execute"><command>chromium</command></action>
      </item>
      <separator/>
      <item label="Network Manager">
        <action name="Execute"><command>nm-connection-editor</command></action>
      </item>
    </menu>
    
    <!-- Office -->
    <menu id="office" label="Office">
      <item label="LibreOffice Writer">
        <action name="Execute"><command>libreoffice --writer</command></action>
      </item>
      <item label="LibreOffice Calc">
        <action name="Execute"><command>libreoffice --calc</command></action>
      </item>
      <item label="LibreOffice Impress">
        <action name="Execute"><command>libreoffice --impress</command></action>
      </item>
      <separator/>
      <item label="Document Viewer">
        <action name="Execute"><command>evince</command></action>
      </item>
    </menu>
    
    <!-- Graphics -->
    <menu id="graphics" label="Graphics">
      <item label="GIMP">
        <action name="Execute"><command>gimp</command></action>
      </item>
      <item label="Inkscape">
        <action name="Execute"><command>inkscape</command></action>
      </item>
      <separator/>
      <item label="Image Viewer">
        <action name="Execute"><command>eog</command></action>
      </item>
      <item label="Screenshot">
        <action name="Execute"><command>scrot</command></action>
      </item>
    </menu>
    
    <!-- Multimedia -->
    <menu id="multimedia" label="Multimedia">
      <item label="VLC Media Player">
        <action name="Execute"><command>vlc</command></action>
      </item>
      <item label="MPV Player">
        <action name="Execute"><command>mpv</command></action>
      </item>
      <separator/>
      <item label="Audacity">
        <action name="Execute"><command>audacity</command></action>
      </item>
      <item label="Kdenlive">
        <action name="Execute"><command>kdenlive</command></action>
      </item>
      <item label="OBS Studio">
        <action name="Execute"><command>obs</command></action>
      </item>
    </menu>
    
    <!-- Development -->
    <menu id="development" label="Development">
      <item label="VS Code">
        <action name="Execute"><command>code</command></action>
      </item>
      <item label="Geany">
        <action name="Execute"><command>geany</command></action>
      </item>
      <separator/>
      <item label="Git GUI">
        <action name="Execute"><command>git-gui</command></action>
      </item>
      <item label="Gitk">
        <action name="Execute"><command>gitk</command></action>
      </item>
    </menu>
    
    <separator label="System"/>
    
    <!-- System Tools -->
    <menu id="system" label="System">
      <item label="File Manager">
        <action name="Execute"><command>pcmanfm</command></action>
      </item>
      <item label="Terminal">
        <action name="Execute"><command>lxterminal</command></action>
      </item>
      <separator/>
      <item label="System Monitor">
        <action name="Execute"><command>gnome-system-monitor</command></action>
      </item>
      <item label="Disk Usage">
        <action name="Execute"><command>ncdu</command></action>
      </item>
      <item label="GParted">
        <action name="Execute"><command>gparted</command></action>
      </item>
    </menu>
    
    <!-- Settings -->
    <menu id="settings" label="Settings">
      <item label="Appearance">
        <action name="Execute"><command>lxappearance</command></action>
      </item>
      <item label="ObConf">
        <action name="Execute"><command>obconf</command></action>
      </item>
      <separator/>
      <item label="Network Manager">
        <action name="Execute"><command>nm-applet</command></action>
      </item>
      <item label="Bluetooth">
        <action name="Execute"><command>blueman-applet</command></action>
      </item>
      <item label="Printing">
        <action name="Execute"><command>system-config-printer</command></action>
      </item>
    </menu>
    
    <!-- Help -->
    <menu id="help" label="Help">
      <item label="CoolOS Documentation">
        <action name="Execute"><command>xdg-open https://github.com/itriedcoding/CoolOS</command></action>
      </item>
      <item label="Report Issue">
        <action name="Execute"><command>xdg-open https://github.com/itriedcoding/CoolOS/issues</command></action>
      </item>
    </menu>
    
    <separator/>
    
    <!-- Session -->
    <item label="Logout">
      <action name="Exit"><prompt>Logout from CoolOS?</prompt></action>
    </item>
    <item label="Reboot">
      <action name="Execute"><command>systemctl reboot</command></action>
    </item>
    <item label="Shutdown">
      <action name="Execute"><command>systemctl poweroff</command></action>
    </item>
  </menu>
</openbox_menu>
